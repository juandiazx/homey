# Copy this file to .env and fill in your values
# cp .env.example .env

# Required: OpenAI credentials for AI-powered search and embeddings
OPENAI_API_KEY=sk-your-key-here
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# MySQL credentials — used by both the db and api services
MYSQL_ROOT_PASSWORD=homey_root
MYSQL_DATABASE=homey
MYSQL_USER=homey
MYSQL_PASSWORD=homey_pass

# Used by the api when running locally (not in Docker — Docker overrides this to use the db service)
DATABASE_URL=mysql+aiomysql://homey:homey_pass@localhost:3306/homey

# CORS allowed origins
CORS_ORIGINS=http://localhost:4173

# JSON structured logging (recommended for Docker)
LOG_JSON_OUTPUT=true
